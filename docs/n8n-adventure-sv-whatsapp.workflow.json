{
  "name": "Adventure-sv WhatsApp Itinerary",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "adventure-sv-whatsapp",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "meta-verify-webhook",
      "name": "Meta Webhook Verification",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 80],
      "webhookId": "adventure-sv-whatsapp-verify"
    },
    {
      "parameters": {
        "jsCode": "const query = $json.query ?? {};\nconst mode = query['hub.mode'];\nconst token = query['hub.verify_token'];\nconst challenge = query['hub.challenge'];\n\nif (mode !== 'subscribe' || token !== 'Adventure-sv' || !challenge) {\n  throw new Error('Invalid Meta webhook verification request');\n}\n\nreturn [{ json: { challenge } }];"
      },
      "id": "meta-verify-code",
      "name": "Validate Meta Verification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 80]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "={{$json.challenge}}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "meta-verify-response",
      "name": "Return Meta Challenge",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [760, 80]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "adventure-sv-whatsapp",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "1",
      "name": "WhatsApp Inbound Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "adventure-sv-whatsapp"
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nconst value = body.entry?.[0]?.changes?.[0]?.value;\nconst message = body.message || body.text || body.body?.message || body.body?.text || body.messages?.[0]?.text?.body || value?.messages?.[0]?.text?.body || '';\nconst phone = body.phone || body.from || body.body?.phone || body.messages?.[0]?.from || value?.messages?.[0]?.from || null;\nreturn [{ json: { message, phone, raw: body } }];"
      },
      "id": "2",
      "name": "Normalize WhatsApp Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{($env.ADVENTURE_SV_API_URL || 'http://host.docker.internal:4000') + '/api/webhooks/n8n/whatsapp'}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{JSON.stringify({ message: $json.message, phone: $json.phone })}}",
        "options": {}
      },
      "id": "3",
      "name": "Call Adventure-sv Backend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [780, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}",
        "options": {}
      },
      "id": "4",
      "name": "Return Backend Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1040, 300]
    }
  ],
  "connections": {
    "Meta Webhook Verification": {
      "main": [
        [
          {
            "node": "Validate Meta Verification",
